# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas — plain password (special chars like @ are handled automatically)
MONGODB_USER=your_db_user
MONGODB_PASSWORD=your_plain_password
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
MONGODB_DB_NAME=file_my_complain

# Or full URI (comment out the 4 lines above if using this):
# MONGODB_URI="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/file_my_complain?retryWrites=true&w=majority"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Default admin account (created on first server start if not exists)
ADMIN_EMAIL=admin@filethecomplaint.in
ADMIN_PASSWORD=admin123

# CORS (optional - set to your frontend URL in production)
CLIENT_URL=http://localhost:5000
